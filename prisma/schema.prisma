generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Account {
  id               String   @id @default(cuid())
  clerkId          String   @unique
  email            String   @unique
  name             String?
  image            String?
  subscription     String   @default("free")
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  resumes      Resume[]
  applications Application[]
  interviews   InterviewSession[]
  leaderboard  Leaderboard?
  coachChats   CoachChat[]
}

model Resume {
  id               String   @id @default(cuid())
  userId           String
  user             Account  @relation(fields: [userId], references: [clerkId])

  name             String   @default("My Resume")
  originalFileName String?
  originalUrl      String   @default("pending")
  optimizedUrl     String?

  parsedText       String?  @db.Text
  atsScore         Int?     @default(0)

  // AI Analysis — stored as JSON
  jsonData         Json?    // full AI output (strengths, weaknesses, bullets, keywords…)
  skills           String[]
  feedback         String?  @db.Text
  optimizedContent String?  @db.Text

  // Job matching — pgvector embedding
  embedding        Unsupported("vector(1536)")?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  applications Application[]

  @@index([userId])
}

model JobPosting {
  id           String   @id @default(cuid())
  title        String
  company      String
  description  String   @db.Text
  requirements Json
  location     String?
  salaryRange  String?

  // pgvector embedding for semantic matching
  embedding    Unsupported("vector(1536)")?

  createdAt    DateTime @default(now())

  applications Application[]
}

model Application {
  id         String   @id @default(cuid())
  userId     String
  jobId      String
  resumeId   String
  status     String   @default("wishlist") // wishlist | applied | interview | offer | rejected
  matchScore Int?
  notes      String?  @db.Text
  appliedAt  DateTime @default(now())

  // Interview schedule
  interviewDate DateTime?
  nextStep      String?

  user   Account    @relation(fields: [userId], references: [clerkId])
  job    JobPosting @relation(fields: [jobId], references: [id])
  resume Resume     @relation(fields: [resumeId], references: [id])

  @@index([userId])
  @@index([status])
}

model InterviewSession {
  id          String    @id @default(cuid())
  userId      String
  jobTitle    String?
  company     String?
  difficulty  String    @default("medium") // easy | medium | hard
  category    String    @default("mixed")  // behavioral | technical | mixed

  questions   Json[]
  transcript  Json?
  score       Int?
  feedback    String?   @db.Text

  // Communication analysis
  fillerWordCount   Int?
  speakingPaceWpm   Int?
  confidenceScore   Int?
  clarityScore      Int?

  status      String    @default("ongoing") // ongoing | completed
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  user Account @relation(fields: [userId], references: [clerkId])

  @@index([userId])
}

model Leaderboard {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        Account  @relation(fields: [userId], references: [clerkId])
  totalScore  Int      @default(0)
  xp          Int      @default(0)
  level       Int      @default(1)
  rank        Int?
  weeklyScore Int      @default(0)
  badges      String[]
  updatedAt   DateTime @updatedAt
}

model CoachChat {
  id        String   @id @default(cuid())
  userId    String
  user      Account  @relation(fields: [userId], references: [clerkId])
  role      String   // user | assistant
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
}
