generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id               String             @id @default(cuid())
  clerkId          String             @unique
  email            String             @unique
  name             String?
  image            String?
  subscription     String             @default("free")
  stripeCustomerId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  applications     Application[]
  coachChats       CoachChat[]
  interviews       InterviewSession[]
  leaderboard      Leaderboard?
  resumes          Resume[]
}

model Resume {
  id               String        @id @default(cuid())
  userId           String
  name             String        @default("My Resume")
  originalFileName String?
  originalUrl      String        @default("pending")
  optimizedUrl     String?
  parsedText       String?
  atsScore         Int?          @default(0)
  jsonData         Json?
  skills           String[]
  feedback         String?
  optimizedContent String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  applications     Application[]
  user             Account       @relation(fields: [userId], references: [clerkId])

  @@index([userId])
}

model JobPosting {
  id           String        @id @default(cuid())
  title        String
  company      String
  description  String
  requirements Json
  location     String?
  salaryRange  String?
  createdAt    DateTime      @default(now())
  applications Application[]
}

model Application {
  id            String     @id @default(cuid())
  userId        String
  jobId         String
  resumeId      String
  status        String     @default("wishlist")
  matchScore    Int?
  notes         String?
  appliedAt     DateTime   @default(now())
  interviewDate DateTime?
  nextStep      String?
  job           JobPosting @relation(fields: [jobId], references: [id])
  resume        Resume     @relation(fields: [resumeId], references: [id])
  user          Account    @relation(fields: [userId], references: [clerkId])

  @@index([userId])
  @@index([status])
}

model InterviewSession {
  id              String    @id @default(cuid())
  userId          String
  jobTitle        String?
  company         String?
  difficulty      String    @default("medium")
  category        String    @default("mixed")
  questions       Json[]
  transcript      Json?
  score           Int?
  feedback        String?
  fillerWordCount Int?
  speakingPaceWpm Int?
  confidenceScore Int?
  clarityScore    Int?
  status          String    @default("ongoing")
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  user            Account   @relation(fields: [userId], references: [clerkId])

  @@index([userId])
}

model Leaderboard {
  id          String   @id @default(cuid())
  userId      String   @unique
  totalScore  Int      @default(0)
  xp          Int      @default(0)
  level       Int      @default(1)
  rank        Int?
  weeklyScore Int      @default(0)
  badges      String[]
  updatedAt   DateTime @updatedAt
  user        Account  @relation(fields: [userId], references: [clerkId])
}

model CoachChat {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  user      Account  @relation(fields: [userId], references: [clerkId])

  @@index([userId])
}
